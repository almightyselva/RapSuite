@page "/"

<PageTitle>RapSuite - AI Lyrics Creator</PageTitle>

@if (Session.IsAuthenticated)
{
    <div class="dashboard">
        <h2 class="mb-4">Welcome back, @(Session.DisplayName ?? Session.Email) 👋</h2>

        <div class="row">
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card glass-card dashboard-card" @onclick='() => Navigation.NavigateTo("/generate")'>
                    <div class="card-body text-center">
                        <div class="dash-icon">🎤</div>
                        <h4>Generate Lyrics</h4>
                        <p class="text-muted">Create new rap songs from a situation</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card glass-card dashboard-card" @onclick='() => Navigation.NavigateTo("/rephrase")'>
                    <div class="card-body text-center">
                        <div class="dash-icon">🔄</div>
                        <h4>Rephrase to Rap</h4>
                        <p class="text-muted">Transform existing lyrics into rap format</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card glass-card dashboard-card" @onclick='() => Navigation.NavigateTo("/albums")'>
                    <div class="card-body text-center">
                        <div class="dash-icon">💿</div>
                        <h4>My Albums</h4>
                        <p class="text-muted">View and manage your saved lyrics</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
